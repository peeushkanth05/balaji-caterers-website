datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String     // Hash via bcrypt
  phone     String?
  role      String     @default("ADMIN") // "SUPER_ADMIN" | "ADMIN"
  leads     Lead[]     // Formal assignment relation
  auditLogs AuditLog[] // Traceability logs
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  phone        String
  email        String?
  eventType    String
  service      String?
  eventDate    DateTime?
  guestCount   Int?
  message      String?
  status       String    @default("NEW") // "NEW" | "CONTACTED" | "QUOTATION_SENT" | "BOOKED" | "COMPLETED" | "CANCELLED"
  notes        String?
  assignedTo   String?   // User ID
  assignedUser User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model Package {
  id             String   @id @default(cuid())
  name           String
  category       String   // e.g. Wedding, Birthday, Corporate
  pricePerPerson Float
  description    String
  features       String   // Comma-separated list or details
  isFeatured     Boolean  @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isFeatured])
}

model Service {
  id             String   @id @default(cuid())
  title          String
  icon           String   // Emoji or icon name (e.g. 🍽️)
  description    String
  tag            String   // e.g. "Veg & Non-Veg", "Custom Themes"
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, displayOrder])
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  category  String   // e.g. Wedding, Birthday, Floral, DJ
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model SiteSetting {
  id            String   @id @default("default")
  companyName   String   @default("Shree Balaji Caterers")
  logoUrl       String   @default("/new-logo.png")
  faviconUrl    String   @default("/favicon.ico")

  // Business Info
  phone         String   @default("+91 98104 83544")
  whatsapp      String   @default("919810483544")
  email         String   @default("vermasandeep124@gmail.com")
  ownerName     String   @default("Sandeep Verma")
  address       String   @default("Dwarka Sector 5, Madhu Vihar, New Delhi")
  mapsUrl       String   @default("https://www.google.com/maps/search/?api=1&query=28.5921,77.0460&query_place_id=Dwarka+Sector+5+New+Delhi")
  businessHours String   @default("9:00 AM - 9:00 PM (Daily)")

  // Social Links
  facebookUrl   String   @default("")
  instagramUrl  String   @default("")
  youtubeUrl    String   @default("")
  twitterUrl    String   @default("")

  // Analytics & SEO
  googleAnalyticsId String @default("")
  seoTitle      String   @default("Shree Balaji Caterers | Best Catering & Event Services in Delhi NCR")
  seoDescription String  @default("Premium catering, floral décor, DJ & sound, and full event management services in Delhi NCR. 15+ years, 500+ events.")
  seoOgImage    String   @default("/new-logo.png")

  // Editable About Us Content
  aboutTag      String   @default("Why Us")
  aboutTitle    String   @default("Why Choose Shree Balaji Caterers")
  aboutSubtitle String   @default("With 15+ years of experience and 500+ successful events in Delhi NCR, we bring passion, precision, and a personal touch to every celebration.")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =============================================================================
// HERO SECTION — Dynamic CMS Models
// =============================================================================

model HeroSection {
  id               String   @id @default("default")

  // General
  isEnabled        Boolean  @default(true)
  layoutType       String   @default("split")       // "split" | "centered" | "fullwidth"
  backgroundType   String   @default("gradient")     // "image" | "video" | "gradient"
  themeStyle       String   @default("light")        // "light" | "dark" | "glassmorphism"

  // Logo
  logoUrl          String   @default("/new-logo.png")
  logoDarkUrl      String   @default("")
  logoLightUrl     String   @default("")
  logoWidth        Int      @default(48)
  logoHeight       Int      @default(48)
  logoAlt          String   @default("Shree Balaji Caterers Logo")
  logoClickUrl     String   @default("/")

  // Announcement Bar
  announcementShow      Boolean @default(false)
  announcementText      String  @default("")
  announcementIcon      String  @default("📢")
  announcementLink      String  @default("")
  announcementBgColor   String  @default("#f59e0b")
  announcementTextColor String  @default("#ffffff")

  // Badge
  badgeShow        Boolean  @default(true)
  badgeText        String   @default("Delhi NCR's Premier Event Partner")
  badgeIcon        String   @default("⭐")
  badgeColor       String   @default("#f59e0b")

  // Heading
  heading          String   @default("Every Celebration, Perfectly Crafted.")
  headingHighlight String   @default("")
  headingAlignment String   @default("left")         // "left" | "center" | "right"

  // Subheading
  subheading       String   @default("From grand weddings to intimate family gatherings — Shree Balaji Caterers brings you world-class catering, stunning floral décor, seamless sound, and complete event management.")
  subheadingAlignment String @default("left")
  subheadingCharLimit Int    @default(300)

  // Primary Button
  primaryBtnText   String   @default("Book Your Event ✨")
  primaryBtnLink   String   @default("#contact")
  primaryBtnIcon   String   @default("")
  primaryBtnNewTab Boolean  @default(false)

  // Secondary Button
  secondaryBtnText String   @default("View Our Work 🎨")
  secondaryBtnLink String   @default("#portfolio")
  secondaryBtnIcon String   @default("")
  secondaryBtnNewTab Boolean @default(false)

  // Slider Settings
  sliderAutoPlay   Boolean  @default(true)
  sliderSpeed      Int      @default(5000)            // ms between slides
  sliderLoop       Boolean  @default(true)
  sliderPauseOnHover Boolean @default(true)
  sliderNavigation Boolean  @default(true)
  sliderPagination Boolean  @default(true)
  sliderTransition String   @default("fade")          // "fade" | "slide" | "zoom"

  // Background Settings
  bgImage          String   @default("")
  bgVideo          String   @default("")
  overlayColor     String   @default("#000000")
  overlayOpacity   Float    @default(0)
  bgBlur           Int      @default(0)
  bgParallax       Boolean  @default(false)
  bgGradient       String   @default("")

  // Theme Colors
  colorHeading     String   @default("")
  colorSubheading  String   @default("")
  colorButtons     String   @default("")
  colorBadge       String   @default("")
  colorBackground  String   @default("")
  colorOverlay     String   @default("")

  // SEO
  seoTitle         String   @default("Shree Balaji Caterers | Best Catering & Event Services in Delhi NCR")
  seoDescription   String   @default("Premium catering, floral décor, DJ & sound, and full event management services in Delhi NCR. 15+ years, 500+ events.")
  seoImageAlt      String   @default("Shree Balaji Caterers Hero Image")
  seoStructuredData String  @default("")

  // Mobile Overrides
  mobileHeading    String   @default("")
  mobileSubheading String   @default("")
  mobileImage      String   @default("")
  mobileHideElements String @default("")
  mobileBtnText    String   @default("")

  // Relations
  statistics       HeroStatistic[]
  images           HeroImage[]
  floatingCards    HeroFloatingCard[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HeroStatistic {
  id             String   @id @default(cuid())
  heroSectionId  String
  heroSection    HeroSection @relation(fields: [heroSectionId], references: [id], onDelete: Cascade)

  icon           String   @default("📊")
  number         String
  prefix         String   @default("")
  suffix         String   @default("")
  title          String
  sortOrder      Int      @default(0)
  isEnabled      Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([heroSectionId])
}

model HeroImage {
  id             String   @id @default(cuid())
  heroSectionId  String
  heroSection    HeroSection @relation(fields: [heroSectionId], references: [id], onDelete: Cascade)

  imageUrl       String
  mobileImageUrl String   @default("")
  altText        String   @default("Hero Image")
  caption        String   @default("")
  displayOrder   Int      @default(0)
  isEnabled      Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([heroSectionId])
}

model HeroFloatingCard {
  id             String   @id @default(cuid())
  heroSectionId  String
  heroSection    HeroSection @relation(fields: [heroSectionId], references: [id], onDelete: Cascade)

  icon           String
  title          String
  description    String
  link           String   @default("")
  color          String   @default("amber")
  sortOrder      Int      @default(0)
  isEnabled      Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([heroSectionId])
}

// =============================================================================
// ENTERPRISE PORTFOLIO MANAGEMENT MODULE
// =============================================================================

model PortfolioCategory {
  id             String      @id @default(cuid())
  categoryName   String
  slug           String      @unique
  description    String?
  icon           String?     // Emoji or icon class/URL
  bannerImage    String?     // Category banner background
  displayOrder   Int         @default(0)
  active         Boolean     @default(true)
  seoTitle       String?
  seoDescription String?
  portfolios     Portfolio[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Portfolio {
  id               String            @id @default(cuid())
  title            String
  slug             String            @unique
  shortDescription String
  longDescription  String
  categoryId       String
  category         PortfolioCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  coverImage       String
  galleryImages    String            @default("[]") // JSON Array: string[]
  featuredImage    String?
  altText          String?
  seoTitle         String?
  seoDescription   String?
  tags             String            @default("[]") // JSON Array: string[]
  featured         Boolean           @default(false)
  displayOrder     Int               @default(0)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([categoryId])
  @@index([active, featured])
}

// =============================================================================
// AUDIT LOG & CENTRAL MEDIA REGISTRY
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // e.g. "UPDATE_SETTINGS", "DELETE_PORTFOLIO"
  details   String   // JSON string of modifications
  createdAt DateTime @default(now())

  @@index([userId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  filename  String
  url       String   @unique
  publicId  String?  // Cloudinary reference public_id
  folder    String?  @default("general") // Asset folder grouping
  tags      String?  @default("[]") // JSON string array of tags
  altText   String?  // Accessibility alt text
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())

  @@index([folder])
}

model HeaderMenu {
  id           String          @id @default(cuid())
  label        String
  link         String
  displayOrder Int             @default(0)
  submenus     HeaderSubmenu[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([displayOrder])
}

model HeaderSubmenu {
  id           String     @id @default(cuid())
  menuId       String
  menu         HeaderMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label        String
  link         String
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([menuId])
  @@index([displayOrder])
}

model HeaderAction {
  id           String   @id @default(cuid())
  label        String
  link         String
  style        String   @default("primary") // primary, secondary, outline
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
}

model HeaderSettings {
  id           String   @id @default("default")
  stickyHeader Boolean  @default(true)
  topBarActive Boolean  @default(true)
  topBarText   String   @default("Delhi NCR's Premier Event Partner & Caterer!")
  showSocials  Boolean  @default(true)
  showContact  Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}
